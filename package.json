{
  "name": "@yedoma-labs/ichchi-state",
  "version": "0.1.0",
  "description": "Lightweight, TypeScript-first state manager with DevTools and time-travel",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest src",
    "test:run": "vitest run src",
    "test:ui": "vitest --ui src",
    "test:coverage": "vitest run --coverage src",
    "bench": "vitest bench src",
    "bench:run": "vitest bench --run src",
    "demo": "pnpm run build && npx serve . -l 5173",
    "demo:dev": "npx serve . -l 5173",
    "e2e": "npx playwright test",
    "test:e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "e2e:serve": "npx serve examples/e2e -l 5173",
    "e2e:install": "npx playwright install chromium",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test:run && npm run build"
  },
  "keywords": [
    "state",
    "state-management",
    "store",
    "typescript",
    "react",
    "devtools",
    "lightweight"
  ],
  "author": "yedoma-labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yedoma-labs/ichchi-state"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.30",
    "@vitest/coverage-v8": "^4.1.8",
    "happy-dom": "^20.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serve": "^14.2.6",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
