# Ichchi State Demo - Environment Configuration
# Copy this file to .env and customize as needed

# STAGE
# Type: enum | Optional
# Constraints: values: development, production
# Default: development
# Application environment stage
STAGE=development

# API_URL
# Type: url | Required
# API endpoint URL for data fetching
API_URL=http://localhost:3000

# DEBUG
# Type: boolean | Optional
# Default: false
# Enable debug mode with verbose logging
DEBUG=true

# DEVTOOLS_ENABLED
# Type: boolean | Optional
# Default: false
# Enable Redux DevTools integration
DEVTOOLS_ENABLED=true

# PERSIST_STORAGE
# Type: enum | Optional
# Constraints: values: localStorage, sessionStorage
# Default: localStorage
# Storage mechanism for state persistence
PERSIST_STORAGE=localStorage

# LOG_LEVEL
# Type: enum | Optional
# Constraints: values: debug, info, warn, error
# Default: info
# Minimum log level to display
LOG_LEVEL=debug

# TIME_TRAVEL_LIMIT
# Type: integer | Optional
# Constraints: min: 10, max: 200
# Default: 50
# Maximum number of states to keep in time-travel history
TIME_TRAVEL_LIMIT=50
